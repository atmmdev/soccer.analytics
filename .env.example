# Copie para apps/api/.env e preencha os valores.
# Credenciais locais de referência: SENHAS.md (não versionado).

# Database
DATABASE_URL=postgresql://soccer:soccer@localhost:5432/soccer_analytics

# Redis
REDIS_URL=redis://localhost:6379

# Auth (admin único) — preencher localmente
ADMIN_EMAIL=
ADMIN_PASSWORD=
JWT_SECRET=
JWT_EXPIRATION=15m
JWT_REFRESH_SECRET=
JWT_REFRESH_EXPIRATION=7d

# API
API_PORT=3001
API_URL=http://localhost:3001

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:3001

# Data Engine (API-Football — https://www.api-football.com)
API_FOOTBALL_KEY=
# Plano Pro (opcional — só para o contador de uso no dashboard)
API_FOOTBALL_DAILY_LIMIT=7500
API_FOOTBALL_MINUTE_LIMIT=300
# Sync híbrido: ligas allowlist (API-Football IDs). Default: PL, LaLiga, SerieA, Bundesliga, Ligue1, Brasileirão
# SYNC_LEAGUE_IDS=39,140,135,78,61,71

# AI Engine — opcional (sem chave usa template)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
