# Copie para apps/api/.env e preencha os valores.
# Credenciais locais de referência: SENHAS.md (não versionado).

# Database
DATABASE_URL=postgresql://soccer:soccer@localhost:5432/soccer_analytics

# Redis
REDIS_URL=redis://localhost:6379

# Auth (admin único) — preencher localmente
ADMIN_EMAIL=
ADMIN_PASSWORD=
JWT_SECRET=
JWT_EXPIRATION=15m
JWT_REFRESH_SECRET=
JWT_REFRESH_EXPIRATION=7d

# API
API_PORT=3001
API_URL=http://localhost:3001

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:3001

# Data Engine (API-Football — https://www.api-football.com)
API_FOOTBALL_KEY=
# Plano Pro (opcional — só para o contador de uso no dashboard)
API_FOOTBALL_DAILY_LIMIT=7500
API_FOOTBALL_MINUTE_LIMIT=300
# Sync híbrido: allowlist de ligas (API-Football IDs)
# 1ª+2ª: BR(+Copa BR/Nordeste/Supercopa + regionais), EN(+FA/EFL Cup), FR, DE, IT, NL, PT, ES
# + AR/DK/SE + Champions + Europa League + Conference + Libertadores + Sul-Americana + Amistosos
SYNC_LEAGUE_IDS=71,72,73,612,632,475,624,629,477,602,606,604,628,622,609,610,77,626,627,603,616,608,621,611,520,522,630,623,631,615,607,521,39,40,45,48,61,62,78,79,135,136,88,89,94,95,140,141,128,119,113,2,3,848,13,11,667

# AI Engine — opcional (sem chave usa template)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
